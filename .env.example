# =============================================================================
# Stylic AI — environment template
# Copy to `.env` and fill in real values. Every key here is read by
# app/config.py (or by systemd units in DEPLOYMENT.md). Grouped to match
# the Settings class order, so diffing is easy.
# =============================================================================

# ── MongoDB ───────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGO_DB_NAME=stylicai

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
# 15 min access in dev; prod uses long-lived app sessions (see .env).
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── SMTP (Hostinger or similar) ───────────────────────────────────────────
SMTP_SERVER=smtp.hostinger.com
SMTP_PORT=587
SMTP_EMAIL=you@yourdomain.com
SMTP_PASSWORD=your-smtp-password

# ── Resend (preferred transactional mail — falls back to SMTP when empty) ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Cloudflare R2 (see cloudflare-r2-guide.md) ───────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
# Public URL base (no trailing slash): custom domain or https://pub-xxxxx.r2.dev
R2_PUBLIC_URL=https://cdn.yourdomain.com
# Optional: full S3 endpoint override (default is https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com).
R2_ENDPOINT_URL=

# ── Firebase (Google Sign-In) ─────────────────────────────────────────────
# Path to your Firebase service account JSON file.
FIREBASE_SERVICE_ACCOUNT_KEY=./serviceAccountKey.json

# ── Gemini AI ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-image
GEMINI_VISION_MODEL=gemini-2.5-flash

# ── SeedDream / kie.ai (legacy key — also the default KIE_API_KEY when that
#    is left blank below) ──────────────────────────────────────────────────
SEEDDREAM_API_KEY=your-seeddream-api-key
SEEDDREAM_MODEL=seedream/5-lite-image-to-image
# Legacy — unused by the multi-provider pipeline, kept for back-compat tooling.
PHOTOSHOOT_GENERATE_MODEL=nano-banana-pro
SEEDDREAM_QUALITY=high
SEEDDREAM_ASPECT=9:16
SEEDDREAM_MAX_RETRIES=40
SEEDDREAM_RETRY_DELAY=3

# ── Realism pass (nano-banana-pro) — runs after SeedDream, before Modal ───
REALISM_MODEL=nano-banana-pro
REALISM_QUALITY=4K
REALISM_ASPECT=9:16

# ── Model face generation (kie.ai, Gemini 3 Pro Image) ────────────────────
MODEL_FACE_GENERATE_MODEL=nano-banana-pro
MODEL_FACE_GENERATE_ASPECT=4:5
MODEL_FACE_GENERATE_RESOLUTION=1K

# ── Reference-photo model face (SeedDream 5.0 Lite img2img) ────────────────
MODEL_FACE_REFERENCE_SEEDREAM_IMG2IMG_MODEL=seedream/5-lite-image-to-image
MODEL_FACE_REFERENCE_SEEDREAM_MODEL=seedream/5-lite-text-to-image
# kie 5-lite enum: 1:1, 4:3, 3:4, 16:9, 9:16, 2:3, 3:2, 21:9 (no 4:5 — 3:4 is portrait).
MODEL_FACE_REFERENCE_SEEDREAM_ASPECT=3:4
MODEL_FACE_REFERENCE_SEEDREAM_QUALITY=basic

# ── Pose mannequin (SeedDream 5.0 Lite txt2img / img2img) ──────────────────
POSE_MANNEQUIN_SEEDREAM_TEXT_MODEL=seedream/5-lite-text-to-image
POSE_MANNEQUIN_SEEDREAM_IMG2IMG_MODEL=seedream/5-lite-image-to-image
POSE_MANNEQUIN_SEEDREAM_ASPECT=9:16
POSE_MANNEQUIN_SEEDREAM_QUALITY=basic

# ── Multi-provider photoshoot pipeline (LangGraph agents) ─────────────────
# Provider fallback chain:  kie_nb2 → vertex_nb2 → vertex_nbpro → evolink_nb2
# Each is optional; set only the providers you want enabled.
# If KIE_API_KEY is empty the pipeline falls back to SEEDDREAM_API_KEY above.
KIE_API_KEY=
# Vertex / google-genai uses this key for both nano-banana-2 and nano-banana-pro.
GOOGLE_CLOUD_API_KEY=
# Evolink is the final fallback generator.
EVOLINK_API_KEY=

# Per-attempt wall-clock timeout (seconds) for ONE generation call.
PHOTOSHOOT_GEN_PER_IMAGE_TIMEOUT_S=600
# KIE status polling interval (seconds) while waiting on a createTask job.
PHOTOSHOOT_KIE_POLL_INTERVAL_S=2
# Aspect ratio + resolution the providers are asked to produce.
PHOTOSHOOT_GEN_ASPECT_RATIO=9:16
PHOTOSHOOT_GEN_RESOLUTION=4K

# ── App Defaults ──────────────────────────────────────────────────────────
APP_NAME=Stylic AI
DEFAULT_CREDITS=5
DEFAULT_PLAN=free
OTP_EXPIRE_MINUTES=10

# ── Credits (per image) ───────────────────────────────────────────────────
CREDIT_SINGLE_PHOTOSHOOT_PER_IMAGE=8
CREDIT_REGENERATE_PER_IMAGE=8
CREDIT_BACKGROUND_CHANGE_PER_IMAGE=9
CREDIT_UPSCALE_4X_PER_IMAGE=2
CREDIT_UPSCALE_8X_PER_IMAGE=4
CREDIT_BRANDING_PER_IMAGE=1
CREDIT_RESIZE_PER_IMAGE=2
CREDIT_ADJUST_IMAGE_PER_IMAGE=2
CREDIT_FABRIC_CHANGE_PER_IMAGE=9
CREDIT_TEXTURE_CHANGE_PER_IMAGE=9
CREDIT_COLOR_CHANGE_PER_IMAGE=9

# ── Modal GPU enhancement pipeline ────────────────────────────────────────
# Class names must match what is currently DEPLOYED on Modal (run
# `modal deploy modal_realism_pipeline.py` first, then update these).
MODAL_APP_NAME=fashion-realism
MODAL_CLS_PRIMARY=FashionRealismT4
MODAL_CLS_FALLBACK=FashionRealismL4

# ── Upscale provider switch ───────────────────────────────────────────────
# modal | kie — KIE is the default in production.
WHICH_UPSCALE=kie
KIE_UPSCALE_MODEL=topaz/image-upscale
KIE_UPSCALE_FACTOR=2
KIE_REQUEST_RETRIES=3
KIE_HTTP_TIMEOUT=300

# ── Upscale variant encoding (LOSSLESS by default — quality is preserved) ──
# png_fast      = lossless PNG, fast compression (~3-6s @ 8K, ~130 MB). DEFAULT.
# png           = lossless PNG, balanced compression (~15-25s @ 8K, ~100 MB).
# webp_lossless = lossless WebP (~4-8s @ 8K, ~40 MB — same pixels, smaller files).
# jpeg          = LOSSY. Do NOT use without explicit product approval.
KIE_VARIANT_FORMAT=png_fast
KIE_VARIANT_JPEG_QUALITY=95

# ── KIE upscale wait ceiling ──────────────────────────────────────────────
# Hard wall-clock ceiling for a single upscale job (submit + poll + download).
# Poll cadence uses PHOTOSHOOT_KIE_POLL_INTERVAL_S above. Set generously —
# Topaz can legitimately take 3-10 min on busy days.
KIE_UPSCALE_MAX_WAIT_S=900

# ── KIE account-wide rate limiter (Redis sliding window) ──────────────────
# KIE enforces ~20 createTask / 10 s per account. We keep submissions well
# under that cap so bursts + poll traffic + retries never trip a 429. Raise
# KIE_RATE_LIMIT_MAX toward 18 once the pipeline is stable. Disable only in
# local dev where you have the KIE account entirely to yourself.
KIE_RATE_LIMIT_ENABLED=true
KIE_RATE_LIMIT_MAX=10
KIE_RATE_LIMIT_WINDOW_S=10
KIE_RATE_LIMIT_KEY_PREFIX=kie:createTask
KIE_RATE_LIMIT_MAX_WAIT_S=60
KIE_RATE_LIMIT_429_SLEEP_S=5

# ── Redis / Celery ────────────────────────────────────────────────────────
# Production: `redis://:STRONG_PASSWORD@127.0.0.1:6379/0` (see DEPLOYMENT.md §6).
REDIS_URL=redis://localhost:6379/0

# ── Flower UI basic auth (used by stylicai-flower.service) ────────────────
# Format: `user:password`. Serves https://flower.stylic.ai in production.
FLOWER_BASIC_AUTH=admin:change-me-strong-password

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=False

# ── Runtime environment ───────────────────────────────────────────────────
# One of: development | staging | production. Controls CORS defaults,
# /docs exposure, HSTS, and error verbosity.
ENVIRONMENT=production

# ── HTTP security ─────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins. MUST be set explicitly
# in production (no wildcards). Example:
#   CORS_ORIGINS=https://app.stylic.ai,https://stylic.ai
CORS_ORIGINS=https://app.stylic.ai,https://stylic.ai
# Comma-separated allowed Host header values (defends against Host
# poisoning). "*" disables the check; set explicitly in production.
TRUSTED_HOSTS=api.stylic.ai
# Hard ceiling on incoming request body (MiB). Protects workers.
MAX_REQUEST_BODY_MB=20
# Shared secret for ops endpoints (/queue/*). Sent as `X-Admin-Key`.
# Leave empty to fully disable those endpoints in production.
ADMIN_API_KEY=change-me-long-random-string
# Expose Swagger /docs in production. Leave False unless protected.
ENABLE_DOCS_IN_PRODUCTION=False

# ── JWT additional claims (optional, backward compatible) ─────────────────
# Populate once every client has refreshed tokens for stricter validation.
JWT_ISSUER=
JWT_AUDIENCE=

# ── Generic HTTP rate limiting (slowapi, Redis-backed) ────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_GOOGLE=20/minute
