# ── MongoDB ───────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGO_DB_NAME=stylicai

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── SMTP ──────────────────────────────────────────────────────────────────
SMTP_SERVER=smtp.hostinger.com
SMTP_PORT=587
SMTP_EMAIL=you@yourdomain.com
SMTP_PASSWORD=your-smtp-password
# ── Resend (optional, preferred over SMTP when set) ───────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=info@yourdomain.com

# ── Cloudflare R2 (see cloudflare-r2-guide.md) ──────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
# Public URL base (no trailing slash): custom domain or https://pub-xxxxx.r2.dev
R2_PUBLIC_URL=https://cdn.yourdomain.com
# Optional: full S3 API endpoint if not using default https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
# R2_ENDPOINT_URL=

# ── Firebase (Google Sign-In) ─────────────────────────────────────────────
# Path to your Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT_KEY=./serviceAccountKey.json

# ── Gemini AI ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-image
GEMINI_VISION_MODEL=gemini-2.5-flash

# ── SeedDream / kie.ai (legacy single-photoshoot key; also used as the
#    default KIE_API_KEY for the new multi-provider pipeline when
#    KIE_API_KEY is not set explicitly) ─────────────────────────────────────
SEEDDREAM_API_KEY=your-seeddream-api-key
SEEDDREAM_MODEL=seedream/5-lite-image-to-image
SEEDDREAM_QUALITY=high
SEEDDREAM_ASPECT=9:16
SEEDDREAM_MAX_RETRIES=120
SEEDDREAM_RETRY_DELAY=5

# ── Multi-provider photoshoot pipeline (LangGraph agents) ─────────────────
# Provider fallback chain:  kie_nb2 → vertex_nb2 → vertex_nbpro → evolink_nb2
# Each of these is optional; set only the providers you want to enable.
# If KIE_API_KEY is empty the pipeline falls back to SEEDDREAM_API_KEY above.
KIE_API_KEY=
# Vertex / google-genai uses this key for both nano-banana-2 and nano-banana-pro
GOOGLE_CLOUD_API_KEY=
# Evolink is the final fallback generator
EVOLINK_API_KEY=

# Per-attempt wall-clock timeout (seconds) for ONE generation call
PHOTOSHOOT_GEN_PER_IMAGE_TIMEOUT_S=600
# KIE status polling interval (seconds) while waiting on a createTask job
PHOTOSHOOT_KIE_POLL_INTERVAL_S=5
# Aspect ratio + resolution the providers are asked to produce
PHOTOSHOOT_GEN_ASPECT_RATIO=9:16
PHOTOSHOOT_GEN_RESOLUTION=4K

# ── App Defaults ──────────────────────────────────────────────────────────
APP_NAME=Stylic AI
DEFAULT_CREDITS=5
DEFAULT_PLAN=free
OTP_EXPIRE_MINUTES=10

# ── Credits (per image) ───────────────────────────────────────────────────
CREDIT_SINGLE_PHOTOSHOOT_PER_IMAGE=8
CREDIT_REGENERATE_PER_IMAGE=8
CREDIT_BACKGROUND_CHANGE_PER_IMAGE=9
CREDIT_UPSCALE_4X_PER_IMAGE=2
CREDIT_UPSCALE_8X_PER_IMAGE=4
CREDIT_BRANDING_PER_IMAGE=1
CREDIT_RESIZE_PER_IMAGE=2
CREDIT_ADJUST_IMAGE_PER_IMAGE=2
CREDIT_FABRIC_CHANGE_PER_IMAGE=9
CREDIT_TEXTURE_CHANGE_PER_IMAGE=9
CREDIT_COLOR_CHANGE_PER_IMAGE=9

# ── Upscale provider switch ───────────────────────────────────────────────
# modal | kie — KIE is the default; its logic is preserved verbatim.
WHICH_UPSCALE=kie
KIE_UPSCALE_MODEL=topaz/image-upscale
KIE_UPSCALE_FACTOR=2
KIE_REQUEST_RETRIES=3
KIE_HTTP_TIMEOUT=300

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=False
