# ── MongoDB ───────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGO_DB_NAME=stylicai

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── SMTP ──────────────────────────────────────────────────────────────────
SMTP_SERVER=smtp.hostinger.com
SMTP_PORT=587
SMTP_EMAIL=you@yourdomain.com
SMTP_PASSWORD=your-smtp-password

# ── Cloudflare R2 (see cloudflare-r2-guide.md) ──────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
# Public URL base (no trailing slash): custom domain or https://pub-xxxxx.r2.dev
R2_PUBLIC_URL=https://cdn.yourdomain.com
# Optional: full S3 API endpoint if not using default https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
# R2_ENDPOINT_URL=

# ── Firebase (Google Sign-In) ─────────────────────────────────────────────
# Path to your Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT_KEY=./serviceAccountKey.json

# ── Gemini AI ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-image

# ── App Defaults ──────────────────────────────────────────────────────────
APP_NAME=Stylic AI
DEFAULT_CREDITS=5
DEFAULT_PLAN=free
OTP_EXPIRE_MINUTES=10

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=False
